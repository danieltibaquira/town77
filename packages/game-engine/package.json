  },
  "dependencies": {
    "@town77/shared-types": "workspace:*",
    "prando": "^6.0.1"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.1.0",
    "fast-check": "^3.21.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "vite-tsconfig-paths": "^5.0.0"
  }
}
